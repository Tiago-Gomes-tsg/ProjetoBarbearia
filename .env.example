SECRET_KEY=troque-por-uma-chave-longa
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://*.localhost:8000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Em produção: slug.seudominio.com
TENANT_BASE_DOMAIN=localhost
TENANT_ALLOW_SINGLE_FALLBACK=True
TENANT_RESERVED_SUBDOMAINS=www,admin,app,api,plataforma

# Supabase PostgreSQL/Pooler
DATABASE_URL=
DB_CONN_MAX_AGE=60
DB_SSL_REQUIRE=True
# Ative somente se usar o pooler em modo transaction.
DB_DISABLE_PREPARED_STATEMENTS=False

# Supabase Storage (S3). Deixe vazio para usar media/ localmente.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1

# Aceite interno, rate limits e limites globais de upload
TERMS_VERSION=1.0
PRIVACY_POLICY_VERSION=1.0
LOGIN_RATE_LIMIT_IP=10
LOGIN_RATE_LIMIT_USERNAME=5
LOGIN_RATE_LIMIT_WINDOW=900
GEMINI_RATE_LIMIT_USER=10
GEMINI_RATE_LIMIT_WINDOW=60
GEMINI_INSIGHTS_PERIOD=daily
GEMINI_INSIGHTS_CACHE_TIMEOUT=2764800
DATA_UPLOAD_MAX_MEMORY_SIZE=41943040
FILE_UPLOAD_MAX_MEMORY_SIZE=8388608
TENANT_BACKUP_MAX_BYTES=26214400
TENANT_BACKUP_UPLOAD_MAX_BYTES=41943040
TENANT_BACKUP_MAX_RECORDS=100000

# Observabilidade e alertas
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
QUERY_LOGGING_ENABLED=True
ALERT_SLOW_REQUEST_MS=2000
ALERT_ERROR_RATE_PERCENT=5
ALERT_CPU_PERCENT=90
ALERT_MEMORY_MB=512
APP_VERSION=dev
